# Copy this file to .env and fill in your real values.
# Never commit .env — it is gitignored.

# LLM providers — set the key for whichever provider you select in your config
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Search
EXA_API_KEY=your_exa_api_key_here

# Twitter/X — get key at getxapi.com
GETXAPI_KEY=your_getxapi_key_here

# Telegram — get bot token from @BotFather, chat ID by messaging your bot and checking the API
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
